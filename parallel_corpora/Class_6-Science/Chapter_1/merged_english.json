            "end_row_offset_idx": 2,
            "start_col_offset_idx": 0,
            "end_col_offset_idx": 0,
            "text": "Coconut",
            "column_header": false,
            "row_header": false,
            "row_section": false,
            "fillable": false
          },
          {
            "row_span": 1,
            "col_span": 1,
            "start_row_offset_idx": 2,
            "end_row_offset_idx": 2,
            "start_col_offset_idx": 1,
            "end_col_offset_idx": 1,
            "text": "Growth stage",
            "column_header": false,
            "row_header": false,
            "row_section": false,
            "fillable": false
          },
          {
            "row_span": 1,
            "col_span": 1,
            "start_row_offset_idx": 2,
            "end_row_offset_idx": 2,
            "start_col_offset_idx": 2,
            "end_col_offset_idx": 2,
            "text": "Irrigating coconut palms may prevent stunted growth, drooping of leaves and immature nut fall.",
            "column_header": false,
